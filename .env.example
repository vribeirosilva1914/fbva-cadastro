# Copie este arquivo para .env e preencha os valores antes de iniciar em produção

# Chave secreta para sessões (gere uma com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque-por-uma-chave-aleatoria-segura

# Banco de dados (deixe em branco para usar SQLite local)
# Exemplos:
#   SQLite  → não defina DATABASE_URL (padrão)
#   PostgreSQL → postgresql://usuario:senha@host:5432/nome_banco
DATABASE_URL=

# E-mail e senha do administrador inicial (usado apenas no primeiro start)
ADMIN_EMAIL=admin@fbva.org.br
ADMIN_PASSWORD=Admin@2024

# Defina como 1 se o site rodar sob HTTPS (ativa cookie seguro)
HTTPS=0

# Porta do servidor de desenvolvimento (padrão: 5000)
PORT=5000

# Desativa o modo debug em produção (mantenha 0)
FLASK_DEBUG=0
